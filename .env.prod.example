# NEXUS — production .env for docker-compose (single-host EC2 deploy)
# =====================================================================
# Copy this to .env.prod on your EC2 VM, fill every value, NEVER commit.
# Loaded by docker compose via `docker compose --env-file .env.prod up`.
# =====================================================================

# --- Public hostname (drives Caddy TLS + frontend build URLs) ---
# After you allocate an Elastic IP (e.g. 3.14.159.26), rewrite dots as dashes:
#   PUBLIC_HOST=3-14-159-26.nip.io
# nip.io is a free public wildcard DNS — no account needed. Caddy will
# request a Let's Encrypt cert for exactly this hostname on first boot.
#
# PUBLIC_WS_URL MUST include the /ws path suffix — the frontend bundle
# uses this value verbatim as the WebSocket connect URL; without /ws the
# connection lands on the Next.js frontend handler and fails instantly.
PUBLIC_HOST=CHANGE-ME.nip.io
PUBLIC_URL=https://CHANGE-ME.nip.io
PUBLIC_WS_URL=wss://CHANGE-ME.nip.io/ws

# --- Backend server config ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS + x402 resource URLs — must match PUBLIC_URL above.
FRONTEND_URL=https://CHANGE-ME.nip.io

# --- LLM provider keys ---
GROQ_API_KEY=your_groq_key_here
# Leave GEMINI_API_KEY empty if you don't have a valid key — the router
# will skip it. Rate-limit fallback still works with just Groq.
# GEMINI_API_KEY=
# OLLAMA is not usable in the container (would need its own service).

# --- Data source keys ---
NEWSAPI_KEY=
CRYPTOPANIC_KEY=
COINGECKO_API_KEY=
HELIUS_API_KEY=
TWITTER_API_KEY=

# --- Kite chain (testnet) ---
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368

# Deployer private key — keep secret. Needed for agent registration and
# on-chain writes. Use a dedicated testnet-only hot wallet.
DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Contract addresses (already deployed on Kite testnet — these values are fine)
AGENT_REGISTRY_ADDRESS=0xBf23C1A79EfEf28C170cC8895679C4b4E7A97a74
REPUTATION_TRACKER_ADDRESS=0xeE38c91e1dd42A0fc6980Ba8ECc769DFfC5044a9
PAYMENT_ROUTER_ADDRESS=0xd76ea536704252DeD9602eCd549F776aD302c73C
GOVERNANCE_RULES_ADDRESS=0xc7640Bf4fC973ac73bB381cb5a1f1f222db6671b

# --- LLM routing priority ---
LLM_PRIMARY=groq
LLM_FALLBACK=gemini
LLM_EMERGENCY=ollama

# --- Suppress gRPC ALTS noise from Google SDK ---
GRPC_VERBOSITY=ERROR

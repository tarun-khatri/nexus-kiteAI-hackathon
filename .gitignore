# ===========================================================================
# NEXUS — production .gitignore
# Anything in this file MUST NOT be committed. The patterns below are
# deliberately explicit even where they overlap; clarity > brevity.
# ===========================================================================

# --- Secrets (NEVER commit) -------------------------------------------------
# Env files that hold real API keys, deployer private keys, Twitter tokens.
# .env.example / .env.prod.example ARE committed (templates, no secrets).
.env.prod
backend/.env
twitter-service/.env
example-agents/**/.env

# SSH / TLS / crypto private material.
*.pem
*.key
*.crt
*.p12
*.pfx
nexus-prod.pem

# --- Python artifacts -------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
# Virtual environments
venv/
.venv/
env/
ENV/
.python-version

# --- Node / Next.js artifacts ----------------------------------------------
node_modules/
frontend/node_modules/
contracts/node_modules/
twitter-service/node_modules/
example-agents/**/node_modules/
# Next.js build output + TS incremental cache
frontend/.next/
frontend/out/
frontend/build/
*.tsbuildinfo
next-env.d.ts
# Package-manager caches / debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases

# --- Smart-contract build artifacts ----------------------------------------
contracts/cache/
contracts/artifacts/
contracts/typechain/
contracts/typechain-types/

# --- Local databases / data stores -----------------------------------------
*.db
*.sqlite
*.sqlite3
backend/nexus.db
data/

# --- Logs / runtime output -------------------------------------------------
*.log
logs/
deploy.log

# --- Agent / IDE / OS junk -------------------------------------------------
# Claude Code agent local metadata — contains user-specific permission list.
.claude/
# VS Code, JetBrains
.vscode/
.idea/
*.swp
*.swo
*.bak
*.orig
*.rej
# OS-generated
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# --- Deployment / infra -----------------------------------------------------
# Vercel local linkage
.vercel
# Docker-compose override files (local-only dev tweaks)
docker-compose.override.yml
docker-compose.*.local.yml

# --- Misc ------------------------------------------------------------------
dist/
*.tgz
*.tar.gz
/tmp/
/temp/
config.bat

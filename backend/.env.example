# ============================================
# NEXUS - Environment Variables
# All services below are FREE
# ============================================

# --- Free LLM APIs (pick at least one) ---

# Groq (FREE: 30 req/min, Llama 3.3 70B)
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (FREE: 15 req/min, Gemini 2.0 Flash)
# Sign up: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama (FREE: runs locally, no API key needed)
# Install: https://ollama.com
OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.1:8b

# --- Free Data APIs ---

# NewsAPI (FREE: 100 req/day)
# Sign up: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# CryptoPanic (FREE tier available)
# Sign up: https://cryptopanic.com/developers/api/
CRYPTOPANIC_KEY=your_cryptopanic_key_here

# CoinGecko (FREE: no key needed for basic, key for higher limits)
# Sign up: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# --- Kite Blockchain (Testnet = FREE) ---

# Kite Aero Testnet RPC
# Get from: https://docs.gokite.ai/kite-chain/1-getting-started/network-information
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368

# Deployer wallet private key (testnet only - get test tokens from faucet)
# NEVER use a mainnet private key here
DEPLOYER_PRIVATE_KEY=your_testnet_private_key_here

# Deployed contract addresses (fill after deployment)
AGENT_REGISTRY_ADDRESS=
REPUTATION_TRACKER_ADDRESS=
PAYMENT_ROUTER_ADDRESS=
GOVERNANCE_RULES_ADDRESS=

# --- Server Config ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
PUBLIC_URL=http://localhost:8000  # Set to production URL when deployed

# --- LLM Priority (which to try first) ---
# Options: groq, gemini, ollama
LLM_PRIMARY=groq
LLM_FALLBACK=gemini
LLM_EMERGENCY=ollama
